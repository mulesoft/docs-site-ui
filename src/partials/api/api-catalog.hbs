<section class="api-catalog">
  <div class="api-catalog-toolbar">
    <div class="api-catalog-search">
      <input class="input js-api-search" placeholder="Ask a question or search endpoints..." type="search" autocomplete="off">
      <div class="api-suggest js-api-suggest hidden"></div>
    </div>
    <span class="api-catalog-count js-api-count"></span>
    <span class="api-catalog-count js-api-endpoints-total"></span>
  </div>
  <div class="api-catalog-grid js-api-grid"></div>
</section>
<template id="api-card-tmpl">
  <a class="api-card" href="#">
    <div class="api-card-body">
      <h3 class="api-card-title js-card-title"></h3>
      <p class="api-card-description js-card-description"></p>
    </div>
    <div class="api-card-meta">
      <span class="api-card-badge js-card-version"></span>
      <span class="api-card-endpoints js-card-endpoints"></span>
    </div>
  </a>
</template>
<script nonce="**CSP_NONCE**" id="api-data" type="application/json">
[
  {{#each (openapi 'list') as |api|}}
  {
    "title": "{{api.title}}",
    "description": "{{api.description}}",
    "version": "{{api.version}}",
    "url": "{{relativize api.url}}",
    "pathCount": {{api.pathCount}},
    "endpoints": {{{api.endpointsJson}}}
  }{{#unless @last}},{{/unless}}
  {{/each}}
]
</script>
<script nonce="**CSP_NONCE**">//<![CDATA[
;(function () {
  var apis = JSON.parse(document.getElementById('api-data').textContent)
  var grid = document.querySelector('.js-api-grid')
  var countEl = document.querySelector('.js-api-count')
  var endpointsTotalEl = document.querySelector('.js-api-endpoints-total')
  var search = document.querySelector('.js-api-search')
  var suggest = document.querySelector('.js-api-suggest')
  var tmpl = document.getElementById('api-card-tmpl')
  var MAX_SUGGESTIONS = 8

  renderCards()
  search.addEventListener('input', debounce(updateSuggest, 200))
  search.addEventListener('focus', function () { if (search.value) updateSuggest() })
  document.addEventListener('click', function (e) {
    if (!e.target.closest('.api-catalog-search')) suggest.classList.add('hidden')
  })

  function renderCards () {
    var totalEndpoints = 0
    apis.forEach(function (api) {
      var card = document.importNode(tmpl.content.querySelector('.api-card'), true)
      card.href = api.url
      card.querySelector('.js-card-title').textContent = api.title
      card.querySelector('.js-card-description').textContent = api.description || ''
      var versionEl = card.querySelector('.js-card-version')
      if (api.version) {
        versionEl.textContent = 'v' + api.version
      } else {
        versionEl.remove()
      }
      var endpointsEl = card.querySelector('.js-card-endpoints')
      if (api.pathCount > 0) {
        endpointsEl.textContent = api.pathCount + (api.pathCount === 1 ? ' endpoint' : ' endpoints')
        totalEndpoints += api.pathCount
      } else {
        endpointsEl.remove()
      }
      grid.appendChild(card)
    })
    countEl.textContent = apis.length + (apis.length === 1 ? ' API' : ' APIs')
    endpointsTotalEl.textContent = totalEndpoints + (totalEndpoints === 1 ? ' endpoint' : ' endpoints')
  }

  var VERB_TO_METHODS = {
    create: ['POST'], add: ['POST'], insert: ['POST'], register: ['POST'], submit: ['POST'], send: ['POST'], upload: ['POST'], invite: ['POST'], provision: ['POST'], generate: ['POST'], initialize: ['POST'], init: ['POST'], new: ['POST'], make: ['POST'], build: ['POST'], compose: ['POST'], publish: ['POST'], post: ['POST'],
    get: ['GET'], list: ['GET'], fetch: ['GET'], read: ['GET'], show: ['GET'], find: ['GET'], search: ['GET'], view: ['GET'], retrieve: ['GET'], check: ['GET'], look: ['GET'], query: ['GET'], browse: ['GET'], explore: ['GET'], see: ['GET'], display: ['GET'], obtain: ['GET'], pull: ['GET'], load: ['GET'], download: ['GET'], export: ['GET'],
    update: ['PUT', 'PATCH'], edit: ['PUT', 'PATCH'], modify: ['PUT', 'PATCH'], change: ['PUT', 'PATCH'], set: ['PUT', 'PATCH'], configure: ['PUT', 'PATCH'], rename: ['PUT', 'PATCH'], replace: ['PUT'], patch: ['PATCH'], adjust: ['PATCH'], tweak: ['PATCH'], fix: ['PATCH'], correct: ['PATCH'], swap: ['PUT'],
    delete: ['DELETE'], remove: ['DELETE'], revoke: ['DELETE'], disable: ['DELETE'], cancel: ['DELETE'], unassign: ['DELETE'], destroy: ['DELETE'], purge: ['DELETE'], erase: ['DELETE'], drop: ['DELETE'], clear: ['DELETE'], wipe: ['DELETE'], unlink: ['DELETE'], detach: ['DELETE'],
    authenticate: ['POST'], login: ['POST'], authorize: ['POST'], signin: ['POST'], signup: ['POST'],
    deploy: ['POST'], start: ['POST'], stop: ['POST'], restart: ['PATCH', 'POST'], scale: ['PATCH'], trigger: ['POST'], execute: ['POST'], run: ['POST'], launch: ['POST'], activate: ['POST'], enable: ['POST'], deactivate: ['PATCH'], pause: ['PATCH'], resume: ['PATCH']
  }

  // Synonym groups — words in the same group are treated as interchangeable
  var SYNONYMS = {
    user: ['user', 'account', 'profile', 'member', 'person', 'identity', 'participant'],
    org: ['org', 'organization', 'organisation', 'company', 'tenant', 'workspace', 'team'],
    app: ['app', 'application', 'service', 'client', 'project'],
    permission: ['permission', 'role', 'access', 'privilege', 'scope', 'grant', 'entitlement', 'policy'],
    token: ['token', 'key', 'secret', 'credential', 'apikey', 'certificate', 'cert'],
    password: ['password', 'passwd', 'pass', 'secret', 'pin'],
    group: ['group', 'team', 'collection', 'set', 'bundle', 'batch', 'cluster'],
    message: ['message', 'notification', 'alert', 'email', 'sms', 'event', 'signal'],
    file: ['file', 'document', 'attachment', 'blob', 'asset', 'artifact', 'upload', 'resource', 'media', 'image'],
    config: ['config', 'configuration', 'setting', 'preference', 'option', 'parameter', 'property'],
    log: ['log', 'audit', 'history', 'record', 'trace', 'event', 'activity'],
    error: ['error', 'failure', 'fault', 'issue', 'problem', 'exception', 'incident'],
    status: ['status', 'state', 'health', 'condition', 'info', 'detail'],
    job: ['job', 'task', 'process', 'worker', 'queue', 'pipeline', 'workflow', 'batch'],
    env: ['env', 'environment', 'deployment', 'instance', 'stage', 'region'],
    connection: ['connection', 'connector', 'integration', 'link', 'endpoint', 'hook', 'webhook'],
    data: ['data', 'record', 'entry', 'row', 'item', 'object', 'entity', 'payload'],
    schema: ['schema', 'model', 'type', 'definition', 'spec', 'template', 'blueprint'],
    limit: ['limit', 'quota', 'rate', 'throttle', 'cap', 'restriction', 'usage'],
    tag: ['tag', 'label', 'category', 'metadata', 'annotation'],
    version: ['version', 'release', 'revision', 'build', 'iteration']
  }

  // Build a reverse lookup: word → list of synonyms
  var synonymMap = {}
  Object.keys(SYNONYMS).forEach(function (key) {
    SYNONYMS[key].forEach(function (word) {
      synonymMap[word] = SYNONYMS[key]
    })
  })

  var STOP_WORDS = ['how', 'do', 'i', 'can', 'to', 'the', 'a', 'an', 'my', 'all', 'of', 'in', 'on', 'for', 'with', 'is', 'it', 'this', 'that', 'what', 'which', 'using', 'use', 'want', 'need', 'would', 'like', 'me', 'api', 'please', 'should', 'could', 'where', 'when', 'there', 'are', 'was', 'were', 'been', 'being', 'does', 'did', 'has', 'have', 'had', 'about', 'from', 'into', 'through', 'way', 'able', 'endpoint', 'endpoints']

  // Simple stemmer: strip common suffixes to normalize word forms
  function stem (word) {
    if (word.length < 4) return word
    return word
      .replace(/ies$/, 'y')
      .replace(/tion$/, 't')
      .replace(/sion$/, 's')
      .replace(/ment$/, '')
      .replace(/ness$/, '')
      .replace(/ings$/, '')
      .replace(/ing$/, '')
      .replace(/ated$/, 'at')
      .replace(/ised$/, 'is')
      .replace(/ized$/, 'iz')
      .replace(/ful$/, '')
      .replace(/able$/, '')
      .replace(/ible$/, '')
      .replace(/ous$/, '')
      .replace(/ive$/, '')
      .replace(/ence$/, '')
      .replace(/ance$/, '')
      .replace(/ally$/, '')
      .replace(/ly$/, '')
      .replace(/ed$/, '')
      .replace(/er$/, '')
      .replace(/es$/, '')
      .replace(/s$/, '')
  }

  function tokenize (text) {
    // Split on non-alphanumeric, camelCase boundaries, and hyphens
    return text.toLowerCase()
      .replace(/([a-z])([A-Z])/g, '$1 $2')
      .replace(/[^a-z0-9]/g, ' ')
      .split(/\s+/)
      .filter(function (w) { return w.length > 0 })
  }

  // Expand a single token into all forms we should match: stem + synonyms (stemmed)
  function expandToken (token) {
    var stemmed = stem(token)
    var forms = [token, stemmed]
    var syns = synonymMap[token] || synonymMap[stemmed]
    if (syns) {
      syns.forEach(function (s) {
        forms.push(s)
        forms.push(stem(s))
      })
    }
    // Deduplicate
    var seen = {}
    return forms.filter(function (f) {
      if (seen[f]) return false
      seen[f] = true
      return true
    })
  }

  // Fuzzy check: does `haystack` contain something close to `needle`?
  // Uses substring match on stems plus a simple edit-distance-1 check for typos
  function fuzzyMatch (haystack, needle) {
    if (haystack.includes(needle)) return 1.0
    var stemmedNeedle = stem(needle)
    if (stemmedNeedle.length > 2 && haystack.includes(stemmedNeedle)) return 0.8
    // Check if any word in haystack is within edit distance 1
    if (needle.length >= 4) {
      var words = haystack.split(/[\s/\-_{}]+/)
      for (var i = 0; i < words.length; i++) {
        if (words[i].length >= 3 && editDistance1(stem(words[i]), stemmedNeedle)) return 0.5
      }
    }
    return 0
  }

  // Returns true if two strings differ by at most 1 edit (swap, insert, delete, replace)
  function editDistance1 (a, b) {
    var lenDiff = a.length - b.length
    if (lenDiff < -1 || lenDiff > 1) return false
    if (a === b) return true
    var mismatches = 0
    if (a.length === b.length) {
      for (var i = 0; i < a.length; i++) {
        if (a[i] !== b[i]) mismatches++
        if (mismatches > 1) return false
      }
      return true
    }
    // Different lengths: check single insertion/deletion
    var longer = a.length > b.length ? a : b
    var shorter = a.length > b.length ? b : a
    var j = 0
    for (var k = 0; k < longer.length; k++) {
      if (longer[k] !== shorter[j]) {
        mismatches++
        if (mismatches > 1) return false
      } else {
        j++
      }
    }
    return true
  }

  // Extract intent: {verbs: [...], nouns: [...]} from the query tokens
  function extractIntent (tokens) {
    var verbs = []
    var nouns = []
    tokens.forEach(function (t) {
      if (VERB_TO_METHODS[t] || VERB_TO_METHODS[stem(t)]) {
        verbs.push(t)
      } else {
        nouns.push(t)
      }
    })
    return { verbs: verbs, nouns: nouns }
  }

  function scoreEndpoint (ep, tokens, intent) {
    var score = 0
    var summaryLower = (ep.summary || '').toLowerCase()
    var pathLower = ep.path.toLowerCase()
    var pathSegments = pathLower.replace(/\{[^}]*\}/g, '').replace(/[/_-]/g, ' ')
    var methodLower = ep.method.toLowerCase()
    var searchable = summaryLower + ' ' + pathSegments

    var nounHits = 0
    var verbHit = false

    for (var i = 0; i < tokens.length; i++) {
      var token = tokens[i]
      var expanded = expandToken(token)
      var isVerb = VERB_TO_METHODS[token] || VERB_TO_METHODS[stem(token)]
      var bestMatch = 0

      // Check direct method match for verb tokens
      if (isVerb) {
        var methods = VERB_TO_METHODS[token] || VERB_TO_METHODS[stem(token)]
        if (methods && methods.indexOf(ep.method) !== -1) {
          score += 4
          verbHit = true
        }
      }

      if (methodLower === token) {
        score += 3
        verbHit = true
      }

      // Match expanded forms against summary + path
      for (var j = 0; j < expanded.length; j++) {
        var form = expanded[j]
        // Exact substring in summary (highest value)
        var m = fuzzyMatch(summaryLower, form)
        if (m > bestMatch) bestMatch = m
        // Substring in path segments
        var pm = fuzzyMatch(pathSegments, form)
        if (pm > bestMatch) bestMatch = pm
      }

      if (bestMatch > 0) {
        var points = bestMatch >= 1.0 ? 3 : bestMatch >= 0.8 ? 2 : 1
        score += points
        if (!isVerb) nounHits++
      }
    }

    // Bigram bonus: consecutive tokens appearing together in summary/path
    for (var b = 0; b < tokens.length - 1; b++) {
      var bigram = tokens[b] + ' ' + tokens[b + 1]
      var bigramAlt = tokens[b] + tokens[b + 1]
      if (searchable.includes(bigram) || searchable.includes(bigramAlt)) {
        score += 3
      }
    }

    // Intent bonus: if we detected verb+noun intent and both matched, boost
    if (intent.verbs.length > 0 && intent.nouns.length > 0 && verbHit && nounHits > 0) {
      score += 2
    }

    // Coverage bonus: reward endpoints that matched more of the query tokens
    var tokenCount = tokens.length
    if (tokenCount > 1) {
      var coverage = (nounHits + (verbHit ? 1 : 0)) / tokenCount
      if (coverage >= 1.0) score += 3
      else if (coverage >= 0.5) score += 1
    }

    return score
  }

  function updateSuggest () {
    var raw = search.value.trim()
    suggest.innerHTML = ''
    if (!raw) {
      suggest.classList.add('hidden')
      return
    }

    var allTokens = tokenize(raw)
    var tokens = allTokens.filter(function (t) { return STOP_WORDS.indexOf(t) === -1 })
    if (!tokens.length) tokens = allTokens

    var intent = extractIntent(tokens)

    var items = []
    apis.forEach(function (api) {
      ;(api.endpoints || []).forEach(function (ep) {
        var s = scoreEndpoint(ep, tokens, intent)
        if (s > 0) {
          items.push({ type: 'endpoint', method: ep.method, path: ep.path, summary: ep.summary, apiTitle: api.title, url: api.url, operationId: ep.operationId, score: s })
        }
      })
    })

    items.sort(function (a, b) { return b.score - a.score })

    if (!items.length) {
      var empty = document.createElement('div')
      empty.className = 'api-suggest-empty'
      empty.textContent = 'No results for \u201c' + raw + '\u201d'
      suggest.appendChild(empty)
      suggest.classList.remove('hidden')
      return
    }

    var shown = items.slice(0, MAX_SUGGESTIONS)
    shown.forEach(function (item) {
      var row = document.createElement('a')
      row.href = item.url + (item.operationId ? '#op-' + item.operationId : '')
      row.className = 'api-suggest-item'
      row.innerHTML =
        '<span class="api-suggest-method api-suggest-method-' + item.method.toLowerCase() + '">' + item.method + '</span>' +
        '<span class="api-suggest-summary">' + escapeHtml(item.summary || item.path) + '</span>' +
        '<span class="api-suggest-from">' + escapeHtml(item.apiTitle) + '</span>'
      suggest.appendChild(row)
    })
    if (items.length > MAX_SUGGESTIONS) {
      var more = document.createElement('div')
      more.className = 'api-suggest-more'
      more.textContent = '+ ' + (items.length - MAX_SUGGESTIONS) + ' more results'
      suggest.appendChild(more)
    }
    suggest.classList.remove('hidden')
  }

  function escapeHtml (str) {
    var el = document.createElement('span')
    el.textContent = str
    return el.innerHTML
  }

  function debounce (fn, wait) {
    var timeout
    return function () {
      if (timeout) clearTimeout(timeout)
      var self = this
      var args = arguments
      timeout = setTimeout(function () {
        timeout = undefined
        fn.apply(self, args)
      }, wait)
    }
  }
})()
//]]></script>

{{#with (openapi)}}
<div class="openapi-sidebar">
  {{#if info.version}}
    <div class="openapi-sidebar-section">
      <div class="openapi-sidebar-label">Version</div>
      <div class="openapi-sidebar-value">{{info.version}}</div>
    </div>
  {{/if}}
  {{#if operationCount}}
    <div class="openapi-sidebar-section">
      <div class="openapi-sidebar-label">Endpoints</div>
      <div class="openapi-sidebar-value">{{operationCount}}</div>
    </div>
  {{/if}}
  <nav class="openapi-sidebar-nav">
    <a class="openapi-sidebar-link" href="#openapi-overview">Overview</a>
    {{#if hasSecurity}}
      <a class="openapi-sidebar-link" href="#openapi-security">Authentication</a>
    {{/if}}
    {{#if hasTags}}
      {{#if hasMultipleVersions}}
        {{#each versionGroups}}
          <div class="openapi-sidebar-group">
            <span class="openapi-sidebar-group-label">{{version}}</span>
            {{#each operations}}
              <a class="openapi-sidebar-link openapi-sidebar-link-nested openapi-sidebar-endpoint" href="#op-{{operationId}}">
                <span class="openapi-sidebar-method openapi-method-{{methodLower}}">{{method}}</span>
                <span class="openapi-sidebar-summary">{{#if summary}}{{summary}}{{else}}{{path}}{{/if}}</span>
              </a>
            {{/each}}
          </div>
        {{/each}}
      {{else}}
        <div class="openapi-sidebar-group">
          <span class="openapi-sidebar-group-label">Endpoints</span>
          {{#each tags}}
            {{#each operations}}
              <a class="openapi-sidebar-link openapi-sidebar-link-nested openapi-sidebar-endpoint" href="#op-{{operationId}}">
                <span class="openapi-sidebar-method openapi-method-{{methodLower}}">{{method}}</span>
                <span class="openapi-sidebar-summary">{{#if summary}}{{summary}}{{else}}{{path}}{{/if}}</span>
              </a>
            {{/each}}
          {{/each}}
        </div>
      {{/if}}
    {{/if}}
    {{#if hasSchemas}}
      <div class="openapi-sidebar-group">
        <span class="openapi-sidebar-group-label">Schemas</span>
        {{#each schemas}}
          <a class="openapi-sidebar-link openapi-sidebar-link-nested" href="#schema-{{name}}">{{name}}</a>
        {{/each}}
      </div>
    {{/if}}
  </nav>
</div>
<script nonce="**CSP_NONCE**">//<![CDATA[
;(function () {
  var sidebar = document.querySelector('.openapi-sidebar-nav')
  if (!sidebar) return

  function getStickyOffset () {
    var offset = 0
    var toolbar = document.querySelector('.toolbar')
    var topBanner = document.querySelector('.top-banner:not(.hide)')
    var noticeBanner = document.querySelector('.notice-banner')
    if (topBanner) {
      var bannerRect = topBanner.getBoundingClientRect()
      if (bannerRect.bottom > 0) offset += bannerRect.height
    }
    if (toolbar) {
      var toolbarRect = toolbar.getBoundingClientRect()
      if (toolbarRect.bottom > 0) offset += toolbarRect.height
    }
    if (noticeBanner) {
      var noticeRect = noticeBanner.getBoundingClientRect()
      if (noticeRect.bottom > 0) offset += noticeRect.height
    }
    return offset + 20
  }

  sidebar.addEventListener('click', function (e) {
    var link = e.target.closest('a[href^="#"]')
    if (!link) return
    var id = link.getAttribute('href').slice(1)
    var target = document.getElementById(id)
    if (!target) return
    e.preventDefault()
    var top = target.getBoundingClientRect().top + window.scrollY - getStickyOffset()
    window.scrollTo({ top: top, behavior: 'smooth' })
    history.replaceState(null, '', '#' + id)
  })
})()
//]]></script>
{{/with}}
